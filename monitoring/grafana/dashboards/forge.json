{
  "annotations": {
    "list": []
  },
  "description": "Forge — vLLM serving metrics under load. Panels target the metrics vLLM exports at /metrics by default.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "title": "Forge — vLLM serving",
  "uid": "forge-vllm",
  "version": 1,
  "schemaVersion": 39,
  "tags": ["forge", "vllm", "inference"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "In-flight requests",
      "description": "Active vs. queued requests. The gap between them shows when the scheduler is becoming a bottleneck.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "vllm:num_requests_running",
          "legendFormat": "running",
          "refId": "A"
        },
        {
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "waiting",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "KV cache utilization",
      "description": "Fraction of the KV cache currently in use. Saturating at ~1.0 means new requests will queue.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "vllm:gpu_cache_usage_perc",
          "legendFormat": "gpu",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Time to first token (TTFT) — p50 / p95 / p99",
      "description": "Latency between request arrival and first generated token. Goes up under contention.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Time per output token (TPOT) — p50 / p95 / p99",
      "description": "Generation latency per token after the first. Roughly constant on a well-batched engine.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(vllm:time_per_output_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_per_output_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:time_per_output_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Token throughput (tok/s)",
      "description": "Prompt and generation tokens processed per second. The 'output_throughput' headline number comes from here.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(vllm:prompt_tokens_total[1m])",
          "legendFormat": "prompt tok/s",
          "refId": "A"
        },
        {
          "expr": "rate(vllm:generation_tokens_total[1m])",
          "legendFormat": "generation tok/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "End-to-end request latency — p50 / p95 / p99",
      "description": "Full request lifetime (arrival → completion). Combined effect of TTFT + (TPOT × output length).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Request success rate (1m)",
      "description": "Fraction of completed requests vs total in the last minute. < 1.0 indicates errors or preemptions.",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false }
      },
      "targets": [
        {
          "expr": "sum(rate(vllm:request_success_total[1m])) / clamp_min(sum(rate(vllm:request_success_total[1m])) + sum(rate(vllm:num_preemptions_total[1m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Preemptions (1m)",
      "description": "Requests vLLM had to evict mid-flight under cache pressure. Should be near zero in steady state.",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false }
      },
      "targets": [
        {
          "expr": "sum(rate(vllm:num_preemptions_total[1m])) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Tokens processed (1m, total)",
      "description": "Prompt + generation tokens through the engine in the last minute.",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false }
      },
      "targets": [
        {
          "expr": "(sum(rate(vllm:prompt_tokens_total[1m])) + sum(rate(vllm:generation_tokens_total[1m]))) * 60",
          "refId": "A"
        }
      ]
    }
  ]
}

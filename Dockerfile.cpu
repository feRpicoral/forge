# CPU vLLM image — local development on M1 / x86_64 (no GPU).
#
# Used to smoke-test the harness without renting a GPU. Build with:
#   docker build -f Dockerfile.cpu -t forge:cpu .
#
# This image is intentionally large and slow — that's the cost of a from-source
# vLLM CPU build. It exists for *correctness validation*, not for benchmark
# numbers. Real numbers come from the CUDA image on RunPod.

FROM python:3.12-slim-bookworm

# Build deps for vLLM's CPU C++ extensions.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        ninja-build \
        git \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

WORKDIR /app

COPY pyproject.toml uv.lock README.md ./
COPY forge/ ./forge/
COPY scripts/ ./scripts/
COPY configs/ ./configs/
COPY constraints/ ./constraints/

# Sync the managed deps (no vLLM — see constraints/serve.txt for why).
RUN uv sync --frozen --no-dev

# Install vLLM out-of-band against the pinned constraints. On linux x86_64 this
# pulls the standard wheel; on darwin arm64 it pulls the macOS wheel. Either
# way, the transformers <5.0 constraint is enforced.
RUN uv pip install -c constraints/serve.txt vllm \
    || (echo "[forge] vLLM install failed — see docs/local-dev.md for the Ollama fallback path." && exit 1)

ENV PATH="/app/.venv/bin:${PATH}"

EXPOSE 8000

CMD ["python", "-m", "scripts.serve"]

# =============================================================================
# Forge environment variables
# =============================================================================
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit secrets.

# -----------------------------------------------------------------------------
# Model selection
# -----------------------------------------------------------------------------
# Hugging Face model identifier served by vLLM.
# - Default for paid GPU run: meta-llama/Llama-3.1-8B-Instruct (gated)
# - For M1 local smoke: Qwen/Qwen2.5-0.5B-Instruct (ungated, tiny)
MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct

# Quantization variant. One of: none | awq | gptq.
# Use `none` for BF16 / full precision; `awq` for the AWQ-INT4 variant.
QUANTIZATION=none

# -----------------------------------------------------------------------------
# vLLM serving config
# -----------------------------------------------------------------------------
# Maximum sequence length (prompt + generation). Reduce if OOM on small GPUs.
MAX_MODEL_LEN=4096

# Maximum number of concurrent sequences the scheduler will batch.
MAX_NUM_SEQS=128

# Port the OpenAI-compatible server binds to.
SERVING_PORT=8000

# Host the server binds to. Use 0.0.0.0 inside containers.
SERVING_HOST=0.0.0.0

# --- CUDA-only block (ignored by the CPU backend) -----------------------------
# Fraction of GPU memory vLLM is allowed to allocate. 0.90 leaves headroom.
GPU_MEMORY_UTILIZATION=0.90

# KV cache dtype. `auto` lets vLLM pick. `fp8` halves KV memory on H100/Ada;
# unsupported on RTX 4090 (Ada has FP8 compute, not FP8 KV cache).
KV_CACHE_DTYPE=auto

# Tensor parallelism (number of GPUs to shard across). Keep at 1 for single-GPU.
TENSOR_PARALLEL_SIZE=1

# -----------------------------------------------------------------------------
# Hugging Face Hub
# -----------------------------------------------------------------------------
# Required to access gated models (e.g. Llama 3.1). Generate at:
# https://huggingface.co/settings/tokens — needs "read" scope.
HF_TOKEN=

# Cache directory for downloaded models. Avoid filling /root on RunPod.
HF_HOME=./.cache/huggingface

# -----------------------------------------------------------------------------
# OpenAI-compat client (used by the benchmark harness and the HF Spaces app)
# -----------------------------------------------------------------------------
# Point at the local vLLM server by default. Override for Ollama:
#   http://localhost:11434/v1
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=not-used-by-vllm

# -----------------------------------------------------------------------------
# Benchmark / observability
# -----------------------------------------------------------------------------
# Where benchmark and eval results land. Each run gets its own subdirectory.
RESULTS_DIR=./results

# Prometheus scrape URL for monitoring. Default targets local vLLM.
PROMETHEUS_URL=http://localhost:9090
